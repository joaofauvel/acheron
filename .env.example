# Acheron Docker Compose configuration
# Copy to .env and customize as needed.

# Shared secret for worker registration. Required. The orchestrator refuses
# to start with the empty string, the placeholder "dev-registration-token",
# or any value shorter than 32 characters. Generate a fresh token with:
#   openssl rand -hex 32
# Workers must send this token in Authorization: Bearer <token> header.
ACHERON_REGISTRATION_TOKEN=

# Dashboard: trust the X-Forwarded-User header from a reverse proxy that
# authenticates the user and strips the header. Set to 1 only when the
# dashboard is behind a trusted reverse proxy (nginx, Caddy, etc.).
# Default is 0 (unauthenticated).
ACHERON_TRUST_REVERSE_PROXY=0

# --- RunPod Serverless workers (Layer 8a+) ---
# Set these to enable the qwen3tts-edge service in docker-compose.yml.
# Leave commented to run the HTTP stub workers instead.

# Your RunPod account API key (https://api.runpod.io/settings).
# RUNPOD_API_KEY=

# Endpoint ID of the qwen3tts RunPod serverless endpoint (created once via
# `runpodctl serverless create` or the RunPod dashboard). The endpoint's
# template must reference ghcr.io/<repo>/acheron-qwen3tts-runpod:<tag>,
# a 24GB GPU (L4 / A5000 / RTX 3090), and the HF-cache network volume.
# QWEN3TTS_RUNPOD_ENDPOINT_ID=

# Edge container runtime config. Uncomment to override worker.yaml defaults.
# These names are forwarded to the qwen3tts edge service by Compose.
# ACHERON_WORKER__WORKER_ID=qwen3tts-1
# ACHERON_WORKER__WORKER_HOST=qwen3tts-edge
# ACHERON_WORKER__PRICE_SOURCE=runpod            # runpod | static | zero
# ACHERON_WORKER__SECURE_CLOUD=false             # quote community-cloud rate
# ACHERON_WORKER__EXECUTION_TIMEOUT_S=1800
