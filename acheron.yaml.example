# Acheron Configuration Settings Example
# Copy this file to acheron.yaml (or configure ACHERON_CONFIG_PATH) to customize Acheron.
#
# Search precedence:
# 1. $ACHERON_CONFIG_PATH (if set)
# 2. ./acheron.yaml or ./acheron.yml
# 3. /etc/acheron/acheron.yaml or /etc/acheron/acheron.yml
#
# Environment variables override values in this file using nested double underscores
# (e.g. ACHERON_ORCHESTRATOR__REGISTRATION_TOKEN overrides orchestrator.registration_token).

orchestrator:
  # Directory where job step-caches and metadata are stored
  data_dir: "/data/jobs"

  # Shared secret for worker registration. If not configured (null or commented out),
  # the orchestrator will automatically generate a secure token and persist it to
  # {data_dir}/.registration_token. Workers must present this token to register.
  # To bypass security completely for development, set the environment variable
  # ACHERON_OPEN_REGISTRATION=1 or set ``open_registration: true`` here.
  # registration_token: "dev-registration-token"
  # open_registration: false

  # Interval in seconds at which the orchestrator health-checks remote workers
  health_check_interval_seconds: 30

  # Grace period in seconds for in-flight jobs to reconcile their persisted
  # state when the orchestrator shuts down. Raise this when the job store is
  # a remote or heavily loaded Redis.
  shutdown_drain_seconds: 5

workers:
  chunking:
    # Maximum character length for each text chunk generated by the local chunker
    max_chunk_length: 250

  packaging:
    # Target audio bitrate for output packaged audiobooks (e.g., m4b)
    bitrate: "128k"

    # Audio codec used by FFmpeg to package files
    codec: "aac"

    # Maximum size in bytes of the WAV fmt chunk header to process (to prevent OOM/DoS)
    max_fmt_chunk_length: 65536

# Platform provider credentials for decoupled health checks.
# API keys can be set here or via environment variables using ${VAR} expansion.
# Workers reference a provider by name via the `health_provider` key in their
# capabilities metadata, and a platform-specific `health_endpoint_id`.
providers:
  runpod:
    # RunPod API key (https://www.runpod.io/get-started/api-keys).
    # Used to query serverless endpoint status when a worker's HTTP probe fails.
    api_key: "${RUNPOD_API_KEY}"
  huggingface:
    # Hugging Face token (https://huggingface.co/settings/tokens).
    # Used to query Inference Endpoint status when a worker's HTTP probe fails.
    api_key: "${HF_API_KEY}"
